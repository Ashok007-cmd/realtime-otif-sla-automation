# Copy this file to .env and replace every value below — these are
# placeholders only. Never commit the real .env (it's gitignored).
# Local-only Docker Postgres is still a real credential if the container
# port is ever exposed beyond localhost, so treat it like one.
OTIF_DB_PASSWORD=change-me-before-use
PGADMIN_EMAIL=admin@otif.local
PGADMIN_PASSWORD=change-me-before-use
